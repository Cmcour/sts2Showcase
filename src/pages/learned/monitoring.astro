          <div class="dash-row"><span class="dr-name">stsBot7</span><span class="dr-pill online">Online</span><span class="dr-cpm">21.0<span class="anomaly-flag">flush</span></span></div>
          <div class="dash-row"><span class="dr-name">stsBot8</span><span class="dr-pill stale">Stale&nbsp;47m</span><span class="dr-cpm zero">&mdash;</span></div>
          <div class="dash-row"><span class="dr-name">stsBot9</span><span class="dr-pill stale">Stale&nbsp;47m</span><span class="dr-cpm zero">&mdash;</span></div>
          <div class="dash-row"><span class="dr-name">stsBot10</span><span class="dr-pill stale">Stale&nbsp;47m</span><span class="dr-cpm zero">&mdash;</span></div>
        </div>
        <div class="d-stat">
          <span class="d-num">5 / 11</span>
          <span class="d-ntext">actually producing<br />112 CPM total</span>
        </div>
