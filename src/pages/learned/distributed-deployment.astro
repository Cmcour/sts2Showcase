      <div class="fleet-tile ready"><span class="ft-name">stsBot8</span><span class="ft-host">10.0.0.60</span><span class="ft-status">Ready</span></div>
      <div class="fleet-tile incident"><span class="ft-name">stsBot9</span><span class="ft-host">10.0.0.75</span><span class="ft-status">Hostname</span></div>
      <div class="fleet-tile ready"><span class="ft-name">stsBot10</span><span class="ft-host">10.0.0.82</span><span class="ft-status">Ready</span></div>
