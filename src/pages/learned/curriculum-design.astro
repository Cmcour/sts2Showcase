  { text: 'Stage 04 · +Poison',            id: 'stage-04' },
  { text: 'Stage 05 · +Shiv',              id: 'stage-05' },
  { text: 'Stage 06 · Full non-power',     id: 'stage-06' },
  { text: 'Stage 07 · Settle',             id: 'stage-07' },
  { text: 'Stage 08 · +Elites',            id: 'stage-08' },
  { text: 'Stage 09 · +Powers',            id: 'stage-09' },
  { text: 'Stage 10 · +Combo · full',      id: 'stage-10' },
  { text: 'Stage 11 · Settle',             id: 'stage-11' },
