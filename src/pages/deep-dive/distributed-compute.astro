      <span class="ft-host">10.0.0.60</span>
      <span class="ft-cpm">— cpm · offline ~11h</span>
    </div>
    <div class="fleet-tile warm">
      <span class="ft-name">stsBot9</span>
      <span class="ft-host">10.0.0.75</span>
      <span class="ft-cpm">13 cpm</span>
    </div>
    <div class="fleet-tile hot">
      <span class="ft-name">stsBot10</span>
      <span class="ft-host">10.0.0.82</span>
      <span class="ft-cpm">25 cpm</span>
    </div>
