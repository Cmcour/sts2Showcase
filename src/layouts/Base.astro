---
interface Props {
  title: string;
  activeTab?: string;
}
const { title, activeTab } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} — STS2 RL Showcase</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
</head>
<body>
  <nav class="nav">
    <a class="nav-brand" href={base}>sts2<span class="dot">·</span>rl</a>
    <div class="nav-tabs">
      <a href={base} class={`nav-tab ${activeTab === 'about' ? 'active' : ''}`}>About</a>
      <a href={`${base}learned/`} class={`nav-tab ${activeTab === 'learned' ? 'active' : ''}`}>What I Learned</a>
      <a href={`${base}deep-dive/`} class={`nav-tab ${activeTab === 'deep-dive' ? 'active' : ''}`}>Deep Dives</a>
    </div>
  </nav>
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<!-- _v5 Workshop Warm nav treatment — 52px sticky, amber-underline active tab. 2026-04-18_ -->
